# 쿠팡 파트너스 API (서버에서만 사용, 클라이언트에 노출 금지)
COUPANG_ACCESS_KEY=your-access-key-here
COUPANG_SECRET_KEY=your-secret-key-here

# 선택: 채널/서브 ID (없으면 비워두면 됨)
COUPANG_SUB_ID=

# 선택: API Base URL (기본값 사용 시 생략 가능)
# COUPANG_BASE_URL=https://api-gateway.coupang.com

# 서버 포트 (기본 3025)
# PORT=3025

# KPI 목표선 (관리자 대시보드 색상 기준)
# 단위: rate는 %, per session은 절대값
# KPI_OUTBOUND_RATE_GOOD=8
# KPI_OUTBOUND_RATE_WARN=4
# KPI_RECIRCULATION_RATE_GOOD=20
# KPI_RECIRCULATION_RATE_WARN=10
# KPI_OUTBOUND_PER_SESSION_GOOD=0.3
# KPI_OUTBOUND_PER_SESSION_WARN=0.15
# KPI_SIGNIFICANCE_PV_HIGH=500
# KPI_SIGNIFICANCE_PV_MEDIUM=200
