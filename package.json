{
  "name": "coupang-price-rank",
  "private": true,
  "version": "1.0.0",
  "description": "쿠팡 파트너스 API 상품 검색 테스트 (최소 기능)",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "tunnel": "cloudflared tunnel --url http://localhost:3025"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lru-cache": "^11.2.6"
  },
  "devDependencies": {
    "cloudflared": "^0.7.1",
    "concurrently": "^8.2.2"
  }
}
